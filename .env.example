# ═══════════════════════════════════════════════════════════════
# Visual Eval - Environment Configuration
# ═══════════════════════════════════════════════════════════════
# Copy to .env and fill in whichever keys you have. Missing keys
# are handled gracefully: the corresponding model is SKIPPED
# rather than crashing the pipeline.
# ═══════════════════════════════════════════════════════════════


# ─── Judge & Decomposition ────────────────────────────────────
# Together AI key for the primary Qwen3.5-397B judge
TOGETHER_API_KEY=

# OpenRouter for fallback judge routing and GPT-Image generation
OPENROUTER_API_KEY=

# Direct provider keys (optional — only needed if overriding
# api_routing in settings.yaml away from default)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=


# ─── T2I Generation Models ───────────────────────────────────
BFL_API_KEY=                    # FLUX 1.1 Pro Ultra / FLUX 2 Max
STABILITY_API_KEY=              # Stable Diffusion 3.5 Large
BRIA_API_KEY=                   # Bria 2.3
FREEPIK_API_KEY=                # Freepik Mystic 2.5
XAI_API_KEY=                    # xAI Aurora
GOOGLE_API_KEY=                 # Google Imagen 3
LEONARDO_API_KEY=               # Leonardo Phoenix / Lucid Origin

# Adobe Firefly requires enterprise credentials
ADOBE_CLIENT_ID=
ADOBE_CLIENT_SECRET=


# ─── Edit Models (additional) ────────────────────────────────
# Most edit models reuse keys above (BFL, Adobe, Bria, Leonardo)
# PhotoRoom and Picsart need separate keys:
PHOTOROOM_API_KEY=
PICSART_API_KEY=


# ─── Optional ────────────────────────────────────────────────
# PIAPI_API_KEY=                # Midjourney v8 (ToS risk, private only)


# ─── Cost Guardrails ─────────────────────────────────────────
# Hard cap across the entire run (generation + judge).
# Alerts fire at 80% of this value.
MAX_TOTAL_COST_USD=300
